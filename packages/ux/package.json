{
  "name": "@aigne/ux",
  "version": "1.0.12-beta.6",
  "description": "AIGNE ux library",
  "publishConfig": {
    "access": "public"
  },
  "author": "Arcblock <blocklet@arcblock.io> https://github.com/blocklet",
  "homepage": "https://github.com/blocklet/ai-studio#readme",
  "license": "ISC",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.js",
  "files": [
    "lib/cjs",
    "lib/dts",
    "lib/esm",
    "LICENSE",
    "package.json",
    "README.md",
    "./*.js",
    "./*.cjs",
    "./*.d.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blocklet/ai-studio.git"
  },
  "scripts": {
    "build": "tsc --build scripts/tsconfig.build.json",
    "clean": "rimraf lib",
    "prepublishOnly": "run-s clean build"
  },
  "exports": {
    ".": {
      "import": "./index.js",
      "require": "./index.cjs",
      "types": "./index.d.ts"
    }
  },
  "dependencies": {
    "@aigne/core": "workspace:^",
    "@blocklet/ai-runtime": "^0.4.213",
    "nanoid": "^5.0.9",
    "react-helmet": "^6.1.0"
  },
  "devDependencies": {
    "@types/react-helmet": "^6.1.11",
    "npm-run-all": "^4.1.5",
    "react": "^19.0.0",
    "rimraf": "^6.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  }
}
